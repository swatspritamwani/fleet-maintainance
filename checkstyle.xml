<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <!-- Exclude generated sources -->
  <module name="BeforeExecutionExclusionFileFilter">
    <property name="fileNamePattern" value=".*[\\/]generated[\\/].*\.java$"/>
  </module>
  <module name="BeforeExecutionExclusionFileFilter">
    <property name="fileNamePattern" value=".*[\\/]generated-sources[\\/].*\.java$"/>
  </module>

  <module name="TreeWalker">

    <!-- No wildcard imports -->
    <module name="AvoidStarImport"/>

    <!-- Unused imports -->
    <module name="UnusedImports"/>

    <!-- Max method length (40 lines per .ai/skills/cicd-quality.md) -->
    <module name="MethodLength">
      <property name="max" value="40"/>
    </module>

    <!-- No magic numbers in domain/application layers -->
    <module name="MagicNumber">
      <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
      <property name="ignoreAnnotation" value="true"/>
      <property name="ignoreHashCodeMethod" value="true"/>
    </module>

    <!-- Braces required -->
    <module name="NeedBraces"/>

    <!-- Whitespace around operators -->
    <module name="WhitespaceAround"/>

    <!-- No trailing whitespace -->
    <module name="Regexp">
      <property name="format" value="[ \t]+$"/>
      <property name="illegalPattern" value="true"/>
      <property name="message" value="Trailing whitespace"/>
    </module>

    <!-- One statement per line -->
    <module name="OneStatementPerLine"/>

    <!-- Modifier order: public protected private abstract static final ... -->
    <module name="ModifierOrder"/>

  </module>

  <!-- Files end with newline -->
  <module name="NewlineAtEndOfFile">
    <property name="lineSeparator" value="lf"/>
  </module>

  <!-- No tab characters -->
  <module name="FileTabCharacter"/>

</module>
