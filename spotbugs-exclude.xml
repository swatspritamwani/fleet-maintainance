<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                        https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

  <!-- Suppress all findings in generated OpenAPI code -->
  <Match>
    <Package name="~com\.fleet\.maintenance\.bff\.api\..*"/>
  </Match>
  <Match>
    <Package name="~com\.fleet\.maintenance\.bff\.dto\..*"/>
  </Match>

</FindBugsFilter>
